#!/usr/bin/env sh
# qt-251: validate all contract YAML files against the schema before pushing.
# Without this, a broken YAML file could land on main, ship to npm via
# the next release, and break every consumer's scan on `npm install`.
#
# Skip with SKIP_PREPUSH=1 if you need to push a WIP branch (e.g. during
# a rebase cleanup), but never to main.

if [ "${SKIP_PREPUSH:-0}" = "1" ]; then
  echo "[pre-push] SKIP_PREPUSH=1 set — skipping validate. Don't merge to main without re-running."
  exit 0
fi

echo "[pre-push] Validating contracts against schema..."
if npm run --silent validate; then
  echo "[pre-push] PASS: all contracts valid."
  exit 0
else
  echo ""
  echo "[pre-push] FAIL: contract validation errors above. Fix and re-push."
  echo "[pre-push] Or override with SKIP_PREPUSH=1 git push (don't push to main)."
  exit 1
fi
