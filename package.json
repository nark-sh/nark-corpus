{
  "name": "nark-corpus",
  "version": "0.1.0",
  "description": "Behavioral contracts for npm packages — YAML definitions of error handling requirements",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./schema": "./schema/contract.schema.json"
  },
  "files": [
    "packages/**/contract.yaml",
    "packages/**/SOURCES.md",
    "packages/**/fixtures/",
    "schema/",
    "index.js",
    "index.d.ts",
    "audit-index.json",
    "deepen-index.json"
  ],
  "license": "CC-BY-4.0",
  "scripts": {
    "validate": "node scripts/validate-contracts.js"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "yaml": "^2.3.4"
  },
  "keywords": ["behavioral-contracts", "nark", "error-handling", "static-analysis", "contracts"]
}
