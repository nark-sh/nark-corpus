{
  "name": "nark-corpus",
  "version": "0.5.0",
  "description": "Contract library for nark — YAML definitions of error handling requirements for npm packages",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./schema": "./schema/contract.schema.json"
  },
  "files": [
    "packages/**/contract.yaml",
    "packages/**/SOURCES.md",
    "packages/**/fixtures/",
    "schema/",
    "index.js",
    "index.d.ts",
    "audit-index.json",
    "deepen-index.json"
  ],
  "license": "CC-BY-4.0",
  "scripts": {
    "validate": "node scripts/validate-contracts.js",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "ajv": "^8.12.0",
    "husky": "^9.1.7",
    "yaml": "^2.3.4"
  },
  "keywords": [
    "nark",
    "contracts",
    "error-handling",
    "static-analysis",
    "npm-packages"
  ]
}
